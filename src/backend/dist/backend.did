type UserProfile = record {name: text;};
type Tshirt = 
 record {
   colors: vec text;
   deliveryCharge: text;
   description: text;
   imageKey: text;
   name: text;
   price: text;
   sizes: vec text;
   stock: nat;
 };
type Contact = 
 record {
   contactLabel: text;
   number: text;
 };
service : {
  addContact: (contact: Contact) -> ();
  addTshirt: (tshirt: Tshirt) -> ();
  detectUserCurrency: (userIp: text) -> (opt text);
  getAllTshirts: () -> (vec Tshirt) query;
  getCallerUserProfile: () -> (opt UserProfile) query;
  getContacts: () -> (vec Contact) query;
  getCurrencyRates: () -> (opt text) query;
  getPaymentQR: () -> (opt blob) query;
  getRatesCachedAt: () -> (int) query;
  getTshirt: (name: text) -> (opt Tshirt) query;
  getUserProfile: (user: principal) -> (opt UserProfile) query;
  getWhatsappNumber: () -> (text) query;
  refreshExchangeRates: () -> (bool);
  removeContact: (contactLabel: text) -> ();
  removeTshirt: (name: text) -> ();
  saveCallerUserProfile: (profile: UserProfile) -> ();
  searchTshirts: (term: text) -> (vec Tshirt) query;
  setPaymentQR: ("blob": blob) -> ();
  setWhatsappNumber: (number: text) -> ();
  updateTshirt: (tshirt: Tshirt) -> ();
}
